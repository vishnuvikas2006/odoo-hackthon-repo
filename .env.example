# Copy this file to .env and fill in real values before running the app.

# MongoDB connection string (local instance or MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/transitops

# Secret used to sign JWT auth tokens — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_string

# Port the API/web server listens on
PORT=5050
